        <!-- Step 2 Legend Entry -->
        <mxCell id="step-2-legend-group" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="100" width="560" x="0" y="170" as="geometry" />
        </mxCell>
        <mxCell id="step-2-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="2" vertex="1" parent="step-2-legend-group">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-2-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Load Balancing&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt;&lt;/b&gt; ALB forwards traffic via Target Group to EC2 instances (t2.micro) in the Auto Scaling Group (min:2 / max:2) across ap-northeast-1a and 1c. Direct internet access is blocked by Security Group.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-2-legend-group">
          <mxGeometry height="100" width="508" x="52" as="geometry" />
        </mxCell>

        <!-- Step 3 Legend Entry -->
        <mxCell id="step-3-legend-group" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="legend-container">
          <mxGeometry height="100" width="560" x="0" y="290" as="geometry" />
        </mxCell>
        <mxCell id="step-3-badge-legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="3" vertex="1" parent="step-3-legend-group">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="step-3-desc-legend" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=14;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Data Persistence&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;-&lt;/font&gt;&lt;/b&gt; Each EC2 instance connects to RDS MySQL (db.t3.micro, 10GB) on port 3306. RDS Security Group restricts access to the app Security Group only. DB Subnet Group spans both public subnets.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="step-3-legend-group">
          <mxGeometry height="100" width="508" x="52" as="geometry" />
        </mxCell>

        <!-- Auxiliary note in legend -->
        <mxCell id="aux-legend-note" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;fontStyle=2;" value="&lt;span style=&quot;color: light-dark(rgb(80,80,80), rgb(200,200,200));&quot;&gt;&lt;i&gt;Monitoring (Auxiliary): CloudWatch monitors EC2 CPU utilization (alarm threshold: 90%) and CPU credit balance for t2.micro instances in the Auto Scaling Group.&lt;/i&gt;&lt;/span&gt;" vertex="1" parent="legend-container">
          <mxGeometry height="70" width="540" x="0" y="410" as="geometry" />
