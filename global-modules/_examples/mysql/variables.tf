# ---------------------------------------------------------------------------------------------------------------------
# 必須パラメータ
# ---------------------------------------------------------------------------------------------------------------------

variable "db_username" {
  description = "データベースのユーザー名"
  type        = string
  sensitive   = true
}

variable "db_password" {
  description = "データベースのパスワード"
  type        = string
  sensitive   = true
}

# ---------------------------------------------------------------------------------------------------------------------
# オプションパラメータ
# ---------------------------------------------------------------------------------------------------------------------

variable "db_name" {
  description = "データベース名"
  type        = string
  default     = "example_database"
}
